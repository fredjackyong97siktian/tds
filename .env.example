THEFT_API_APP_NAME=Theft Detection API
THEFT_API_APP_VERSION=0.1.0
THEFT_API_DEBUG=false
THEFT_API_TRANSACTIONAL_DATABASE_URL=mysql+pymysql://theft_api:change_me@host.docker.internal:3306/sesamedb
THEFT_API_VECTOR_DATABASE_URL=postgresql+psycopg://postgres:postgres@host.docker.internal:5432/theft_detection_gallery
THEFT_API_PYTHON_BIN=python
THEFT_API_FFMPEG_BIN=ffmpeg
THEFT_API_VIDEO_STORAGE_DIR=/app/session
THEFT_API_CREDENTIAL_SECRET=change_this_to_a_long_random_secret
# Dahua host/IP/username/password are now configured per location in tds_location_endpoint.
THEFT_API_DAHUA_RTSP_PORT=554
THEFT_API_DAHUA_PLAYBACK_SUBTYPE=0
THEFT_API_DAHUA_OUTPUT_VIDEO_CODEC=libx264
THEFT_API_DAHUA_OUTPUT_PRESET=veryfast
THEFT_API_DAHUA_OUTPUT_CRF=23
THEFT_API_SPACES_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
THEFT_API_SPACES_REGION=sgp1
THEFT_API_SPACES_BUCKET=change_me
THEFT_API_SPACES_ACCESS_KEY=change_me
THEFT_API_SPACES_SECRET_KEY=change_me
THEFT_API_SPACES_KEY_PREFIX=tds
THEFT_API_SPACES_PRESIGN_TTL_SECONDS=600
THEFT_API_RETRIEVAL_POLL_SECONDS=10
THEFT_API_RETRIEVAL_MAX_GLOBAL_WORKERS=2
THEFT_API_RETRIEVAL_MAX_PER_LOCATION=1
THEFT_API_THEFT_TRANSACTION_TABLE_NAME=transaction
THEFT_API_THEFT_TRANSACTION_STATUS_COLUMN=status
THEFT_API_THEFT_TRANSACTION_STATUS_VALUE=theft
